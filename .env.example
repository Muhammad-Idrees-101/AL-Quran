# --- PUBLIC VARIABLES ---
# These are exposed to the browser. 
# In Next.js, they must start with NEXT_PUBLIC_

# Primary API for Quran data
NEXT_PUBLIC_QURAN_API=https://api.alquran.cloud

# Backend API URL for custom features (videos, auth, etc.)
NEXT_PUBLIC_API_URL=https://api.example.com

# Analytics ID (e.g., Google Analytics)
NEXT_PUBLIC_ANALYTICS_ID=

# App Environment (development, staging, production)
NEXT_PUBLIC_ENV=development

# --- PRIVATE SECRETS ---
# NEVER prefix these with NEXT_PUBLIC_. 
# These are only accessible on the server-side.

# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Stripe Secret Key (Server-side only)
STRIPE_SECRET_KEY=sk_test_51...

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_token_here

# Internal Service Tokens
INTERNAL_API_KEY=
